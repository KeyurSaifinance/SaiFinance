---

<section class="mx-auto max-w-6xl px-6 py-16 md:px-14" data-review-slider>
    <div class="text-center">
        <span
            class="mx-auto inline-flex items-center justify-center
         gap-2 rounded-full
         border border-[#e5e7eb]
         px-4 py-1
         font-Poppins font-medium
         text-[16px] leading-[30px]
         tracking-normal
         text-center capitalize
         text-[#8A99B6]"
        >
            <img src="/img/flower.png" alt="" />
            Testimonial
            <img src="/img/flower.png" alt="" />
        </span>

        <h2
            class="mx-auto mt-4 max-w-[620px] font-Poppins text-[28px] font-semibold leading-[36px] text-primary lg:text-[40px] lg:leading-[50px]"
        >
            Reviews from our customers
        </h2>

        <div class="mx-auto mt-8 max-w-6xl" data-testimonial-slider>
            {
                testimonials.map((item, index) => {
                    const initials = item.name
                        .split(" ")
                        .filter(Boolean)
                        .slice(0, 2)
                        .map((part) => part[0])
                        .join("")
                        .toUpperCase();

                    return (
                        <article
                            data-testimonial-slide
                            class:list={[
                                "flex flex-col rounded-[24px] border border-[#DFE8F4] bg-[#DFE2E7] p-5 shadow-[0_20px_55px_-40px_rgba(15,40,71,0.45)] transition-all duration-300 lg:p-9 md:h-[530px]",
                                index === 0 ? "block" : "hidden",
                            ]}
                        >
                            <div class="flex items-center justify-between gap-3">
                                <div class="inline-flex items-center gap-3 rounded-full px-3 py-2">
                                    {
                                        item.avatar ? (
                                            <img
                                                src={item.avatar}
                                                alt={item.name}
                                                class="h-15 w-15 rounded-full object-cover ring-2 ring-white/90"
                                                loading="lazy"
                                            />
                                        ) : (
                                            <span
                                                class="inline-flex h-15 w-15 items-center justify-center rounded-full bg-[#E8EFFA] font-Poppins text-[13px] font-semibold text-[#102245]"
                                                aria-hidden="true"
                                            >
                                                {initials}
                                            </span>
                                        )
                                    }
                                </div>
                                <div
                                    class="flex items-center gap-1 text-[20px] text-[#F59E0B]"
                                    aria-label={`Rated ${item.rating} out of 5`}
                                >
                                    {Array.from({
                                        length: item.rating,
                                    }).map(() => (
                                        <span aria-hidden="true">&#9733;</span>
                                    ))}
                                </div>
                            </div>

                            <div class="mt-4 flex-1 overflow-y-auto pr-1 text-left">
                                <p class="whitespace-pre-line font-Arial text-[16px] leading-[28px] text-[#213454] lg:text-[17px] lg:leading-[30px]">
                                    {item.quote}
                                </p>
                            </div>


                            <div class="mt-5 flex items-center justify-end border-t border-[#ECF1F8] pt-5">
                                <p class="text-right font-Poppins text-[18px] font-semibold text-[#102245]">
                                    {item.name}
                                </p>
                            </div>
                        </article>
                    );
                })
            }
        </div>

        <div class="mx-auto mt-6 flex max-w-6xl items-center justify-between gap-4">
            <div class="flex items-center gap-2" data-testimonial-dots>
                {
                    testimonials.map((_, index) => (
                        <button
                            type="button"
                            data-testimonial-dot
                            data-index={index}
                            class:list={[
                                "h-2.5 rounded-full transition-all",
                                index === 0
                                    ? "w-8 bg-primary"
                                    : "w-2.5 bg-[#C4D3E9] hover:bg-[#8FA7CC]",
                            ]}
                            aria-label={`Show testimonial ${index + 1}`}
                        />
                    ))
                }
            </div>

            <div class="flex items-center gap-2">
                <button
                    type="button"
                    data-testimonial-prev
                    class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[#CFD8E9] text-primary transition-all hover:-translate-y-0.5 hover:bg-[#EEF3FB]"
                    aria-label="Previous testimonial"
                >
                    &#8592;
                </button>
                <button
                    type="button"
                    data-testimonial-next
                    class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[#CFD8E9] text-primary transition-all hover:-translate-y-0.5 hover:bg-[#EEF3FB]"
                    aria-label="Next testimonial"
                >
                    &#8594;
                </button>
            </div>
        </div>
    </div>
</section>

<script>
    const reviewRoot = document.querySelector("[data-review-slider]");

    if (reviewRoot) {
        const slides = Array.from(
            reviewRoot.querySelectorAll("[data-testimonial-slide]"),
        );
        const dots = Array.from(
            reviewRoot.querySelectorAll("[data-testimonial-dot]"),
        );
        const prevBtn = reviewRoot.querySelector("[data-testimonial-prev]");
        const nextBtn = reviewRoot.querySelector("[data-testimonial-next]");

        if (slides.length > 0) {
            let currentIndex = 0;
            let autoplayId;

            const showSlide = (index) => {
                if (index < 0) {
                    currentIndex = slides.length - 1;
                } else if (index >= slides.length) {
                    currentIndex = 0;
                } else {
                    currentIndex = index;
                }

                slides.forEach((slide, slideIndex) => {
                    const isActive = slideIndex === currentIndex;
                    slide.classList.toggle("block", isActive);
                    slide.classList.toggle("hidden", !isActive);
                    slide.setAttribute("aria-hidden", String(!isActive));
                });

                dots.forEach((dot, dotIndex) => {
                    const isActive = dotIndex === currentIndex;
                    dot.classList.toggle("w-8", isActive);
                    dot.classList.toggle("bg-primary", isActive);
                    dot.classList.toggle("w-2.5", !isActive);
                    dot.classList.toggle("bg-[#C4D3E9]", !isActive);
                    dot.classList.toggle("hover:bg-[#8FA7CC]", !isActive);
                });
            };

            const nextSlide = () => showSlide(currentIndex + 1);
            const prevSlide = () => showSlide(currentIndex - 1);

            const stopAutoplay = () => {
                if (autoplayId) {
                    window.clearInterval(autoplayId);
                }
            };

            const startAutoplay = () => {
                stopAutoplay();
                autoplayId = window.setInterval(nextSlide, 4500);
            };

            prevBtn?.addEventListener("click", () => {
                prevSlide();
                startAutoplay();
            });

            nextBtn?.addEventListener("click", () => {
                nextSlide();
                startAutoplay();
            });

            dots.forEach((dot, dotIndex) => {
                dot.addEventListener("click", () => {
                    showSlide(dotIndex);
                    startAutoplay();
                });
            });

            reviewRoot.addEventListener("mouseenter", stopAutoplay);
            reviewRoot.addEventListener("mouseleave", startAutoplay);

            showSlide(0);
            startAutoplay();
        }
    }
</script>

