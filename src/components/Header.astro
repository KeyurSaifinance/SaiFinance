---
import { Icon } from "astro-icon/components";

const pathname = Astro.url.pathname;
const isActive = (path) => pathname === path;
---

<header class="border-b border-gray-200 bg-white">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2">
            <img src="/img/logo.webp" alt="SAI Finance" class="h-10 w-auto" />
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden items-center gap-8 lg:flex">
            <a
                href="/"
                class:list={[
                    "font-Poppins text-[18px] font-medium leading-[28.18px] tracking-normal hover:opacity-80",
                    isActive("/") ? "text-primary" : "text-[#9CABC3]",
                ]}
            >
                Home
            </a>

            <a
                href="/services"
                class:list={[
                    "flex text-[18px] font-medium leading-[28.18px] tracking-normal hover:text-primary hover:opacity-80 font-Poppins",
                    isActive("/services") ? "text-primary" : "text-[#9CABC3]",
                ]}
            >
                Services
                <Icon name="ph:caret-down" size="16" class="mt-2 ml-1" />
            </a>
            <a href="/calculator"
                type="button"
                class:list={[
                    "flex text-[18px] font-medium leading-[28.18px] tracking-normal hover:text-primary hover:opacity-80 font-Poppins",
                    isActive("/calculator") ? "text-primary" : "text-[#9CABC3]",
                ]}
            >
                Calculators
                <Icon name="ph:caret-down" size="14" class="mt-2 ml-1" />
            </a>
            <a
                href="/blog"
                class:list={[
                    "text-[18px] font-medium leading-[28.18px] tracking-normal hover:text-primary hover:opacity-80 font-Poppins",
                    isActive("/blog") ? "text-primary" : "text-[#9CABC3]",
                ]}
                >Blog</a
            >
            <a
                href="/resources"
                class:list={[
                    "text-[18px] font-medium leading-[28.18px] tracking-normal hover:text-primary hover:opacity-80 font-Poppins",
                    isActive("/resources") ? "text-primary" : "text-[#9CABC3]",
                ]}
                >Resources</a
            >
        </nav>

        <!-- Right Actions -->
        <div class="flex items-center gap-3">
            <a
                href="/contact"
                class="hidden lg:inline-flex items-center gap-4 rounded-full
         px-5 py-2.5
         font-Poppins font-semibold
         text-[16px] leading-[100%] tracking-normal
         text-white shadow-sm hover:opacity-90
         bg-[linear-gradient(270deg,#17284D_0%,#5A72A7_100%)]"
            >
                Get in Touch
                <span
                    class="inline-flex h-6 w-6 items-center justify-center
           rounded-full border border-white/50
           bg-white text-primary"
                >
                    <Icon name="ph:arrow-up-right" size="16" />
                </span>
            </a>

            <button
                class="inline-flex h-10 w-10 items-center justify-center rounded-full text-primary hover:bg-slate-50"
                aria-label="Open menu"
            >
                <Icon name="ph:list" size="20" />
            </button>
        </div>
    </div>
</header>
