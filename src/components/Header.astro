---
import { Icon } from "astro-icon/components";

const pathname = Astro.url.pathname;
const isActive = (path) => pathname === path;
---

<header class="border-b border-gray-200 bg-white">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2">
            <img src="/img/Sai-Finance-Logo.svg" alt="SAI Finance" class="h-10" />
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden items-center gap-8 lg:flex">
            <a
                href="/"
                class:list={[
                    "font-Poppins text-[17px] leading-[28.18px] tracking-normal hover:opacity-80",
                    isActive("/") ? "text-primary" : "text-[#9CABC3]",
                    isActive("/") ? "font-bold" : "font-medium",
                ]}
            >
                Home
            </a>

            <div class="relative group">
                <a
                    href="/services"
                    class:list={[
                        "flex items-center text-[17px]  leading-[28.18px] tracking-normal hover:text-primary hover:opacity-80 font-Poppins",
                        isActive("/services") ? "text-primary" : "text-[#9CABC3]",
                        isActive("/services") ? "font-bold" : "font-medium",
                    ]}
                >
                    Services
                    <Icon
                        name="ph:caret-down"
                        size="16"
                        class="ml-1 transition-transform duration-200 group-hover:rotate-180"
                    />
                </a>
                <div
                    class="invisible absolute left-0 top-full z-20 mt-3 w-60 rounded-2xl border border-[#E6ECF6] bg-white p-3 opacity-0 shadow-[0_20px_40px_-20px_rgba(15,40,71,0.45)] transition-all duration-200 group-hover:visible group-hover:opacity-100"
                >
                    <a
                        href="/services/home-loan"
                        class="block rounded-xl px-4 py-3 font-Arial text-[14px] font-semibold text-[#1E2E4A] hover:bg-[#F5F7FB]"
                    >
                        Home Loan
                    </a>
                    <a
                        href="/services/investors-loan"
                        class="block rounded-xl px-4 py-3 font-Arial text-[14px] font-semibold text-[#1E2E4A] hover:bg-[#F5F7FB]"
                    >
                        Investors Loan
                    </a>
                    <a
                        href="/services/construction-loan"
                        class="block rounded-xl px-4 py-3 font-Arial text-[14px] font-semibold text-[#1E2E4A] hover:bg-[#F5F7FB]"
                    >
                        Construction Loan
                    </a>
                    <a
                        href="/services/commercial-business-loan"
                        class="block rounded-xl px-4 py-3 font-Arial text-[14px] font-semibold text-[#1E2E4A] hover:bg-[#F5F7FB]"
                    >
                        Commercial & Business Loan
                    </a>
                    <a
                        href="/services/smsf-loan"
                        class="block rounded-xl px-4 py-3 font-Arial text-[14px] font-semibold text-[#1E2E4A] hover:bg-[#F5F7FB]"
                    >
                        SMSF Loan
                    </a>
                    <a
                        href="/services/personal-car-loan"
                        class="block rounded-xl px-4 py-3 font-Arial text-[14px] font-semibold text-[#1E2E4A] hover:bg-[#F5F7FB]"
                    >
                        Personal/Car Loan
                    </a>
                </div>
            </div>
            <a href="/calculator"
                type="button"
                class:list={[
                    "flex text-[17px] leading-[28.18px] tracking-normal hover:text-primary hover:opacity-80 font-Poppins",
                    isActive("/calculator") ? "text-primary" : "text-[#9CABC3]",
                    isActive("/calculator") ? "font-bold" : "font-medium",
                ]}
            >
                Calculators
                <Icon name="ph:caret-down" size="14" class="mt-2 ml-1" />
            </a>
            <a
                href="/blog"
                class:list={[
                    "text-[17px] leading-[28.18px] tracking-normal hover:text-primary hover:opacity-80 font-Poppins",
                    isActive("/blog") ? "text-primary" : "text-[#9CABC3]",
                    isActive("/blog") ? "font-bold" : "font-medium",
                ]}
                >Blog</a
            >
            <a
                href="/contact"
                class:list={[
                    "text-[17px] leading-[28.18px] tracking-normal hover:text-primary hover:opacity-80 font-Poppins",
                    isActive("/contact") ? "text-primary" : "text-[#9CABC3]",
                    isActive("/contact") ? "font-bold" : "font-medium",
                ]}
                >contact</a
            >
        </nav>

        <!-- Right Actions -->
        <div class="flex items-center gap-3">
            <a
                href="/contact"
                class="hidden lg:inline-flex items-center gap-4 rounded-full
         px-5 py-2.5
         font-Poppins font-semibold
         text-[16px] leading-[100%] tracking-normal
         text-white shadow-sm hover:opacity-90
         bg-primary"
            >
                Get in Touch
                <span
                    class="inline-flex h-6 w-6 items-center justify-center
           rounded-full border border-white/50
           bg-white text-primary"
                >
                    <Icon name="ph:arrow-up-right" size="16" />
                </span>
            </a>

            <button
                class="inline-flex h-10 w-10 items-center justify-center rounded-full text-primary hover:bg-slate-50"
                aria-label="Open menu"
            >
                <Icon name="ph:list" size="20" />
            </button>
        </div>
    </div>
</header>
