---
import { Icon } from "astro-icon/components";
---

<section class="mx-auto max-w-6xl px-6 lg:py-16 py-10">
    <div class="flex flex-col items-center text-center">
        <span
            class="inline-flex items-center justify-center
         gap-2 rounded-full
         border border-[#e5e7eb]
         px-4 py-1
         font-Poppins font-medium
         text-[16px] leading-[30px]
         tracking-normal
         text-center capitalize
         text-[#8A99B6]"
        >
            <img src="/img/flower.png" alt="" />
            Our Blog
            <img src="/img/flower.png" alt="" />
        </span>

        <h2
            class="mt-5
         font-['Poppins'] font-semibold
         lg:text-[40px] text-[25px] lg:leading-[60px]
         text-center
         bg-[linear-gradient(270deg,#17284D_0%,#5A72A7_100%)]
         bg-clip-text text-transparent"
        >
            Latest News From Us
        </h2>
    </div>

    <div class="lg:mt-16 mt-5 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <!-- Card 1 -->
        <article class="group">
            <div class="flex items-center gap-6 text-[#9AA4B2] mx-5">
                <span class="flex items-center gap-1 text-[15px]">
                    <Icon
                        name="heroicons:user"
                        class="w-4 h-4 text-black -mt-1"
                    />
                    Admin
                </span>
                <span class="flex items-center gap-2 text-[15px]">
                    <Icon
                        name="heroicons:calendar-days"
                        class="w-4 h-4 text-black -mt-1"
                    />
                    October 2, 2025
                </span>
            </div>
            <h3
                class="mt-4
         font-dm-sans font-semibold
         text-[19px] leading-[24px]
         tracking-normal
         bg-[linear-gradient(270deg,#17284D_0%,#5A72A7_100%)]
         bg-clip-text text-transparent mx-5"
            >
                Master the Markets: Trading Tips for Beginners
            </h3>

            <div class="relative mt-6 overflow-hidden rounded-b-2xl bg-[#eef0f6]">
                <img
                    src="/img/blog_img_1.webp"
                    alt="Blog cover"
                    class="h-56 w-full object-cover"
                />
                <span
                    class="absolute left-4 top-4 rounded-full  bg-[linear-gradient(270deg,#17284D_0%,#5A72A7_100%)] px-4 py-1 text-[12px] font-semibold text-white"
                >
                    Business
                </span>
                <a
                    href="/blog/1"
                    class="absolute inset-x-0 bottom-0 translate-y-full bg-[#1d2d53] py-3 text-center text-[14px] font-semibold text-white transition-all duration-300 group-hover:translate-y-0"
                >
                    Read More &#8599;
                </a>
            </div>
        </article>

        <!-- Card 2 -->
        <article class="group">
            <div class="flex items-center gap-6 text-[#9AA4B2] mx-5">
                <span class="flex items-center gap-1 text-[15px]">
                    <Icon
                        name="heroicons:user"
                        class="w-4 h-4 text-black -mt-1"
                    />
                    Admin
                </span>
                <span class="flex items-center gap-2 text-[15px]">
                    <Icon
                        name="heroicons:calendar-days"
                        class="w-4 h-4 text-black -mt-1"
                    />
                    October 2, 2025
                </span>
            </div>
            <h3
                class="mt-4
         font-dm-sans font-semibold
         text-[19px] leading-[24px]
         tracking-normal
         bg-[linear-gradient(270deg,#17284D_0%,#5A72A7_100%)]
         bg-clip-text text-transparent mx-5"
            >
                Understanding Charts: A Quick Guide for Traders
            </h3>

            <div class="relative mt-6 overflow-hidden rounded-b-2xl bg-[#eef0f6]">
                <img
                    src="/img/blog_img_2.webp"
                    alt="Blog cover"
                    class="h-56 w-full object-cover"
                />
                <span
                    class="absolute left-4 top-4 rounded-full bg-white px-4 py-1 text-[12px] font-semibold text-[#1d2d53]"
                >
                    Corporate
                </span>
                <a
                    href="/blog/2"
                    class="absolute inset-x-0 bottom-0 translate-y-full bg-[#1d2d53] py-3 text-center text-[14px] font-semibold text-white transition-all duration-300 group-hover:translate-y-0"
                >
                    Read More &#8599;
                </a>
            </div>
        </article>

        <!-- Card 3 -->
        <article class="group">
            <div class="flex items-center gap-6 text-[#9AA4B2] mx-5">
                <span class="flex items-center gap-1 text-[15px]">
                    <Icon
                        name="heroicons:user"
                        class="w-4 h-4 text-black -mt-1"
                    />
                    Admin
                </span>
                <span class="flex items-center gap-2 text-[15px]">
                    <Icon
                        name="heroicons:calendar-days"
                        class="w-4 h-4 text-black -mt-1"
                    />
                    October 2, 2025
                </span>
            </div>
            <h3
                class="mt-4
         font-dm-sans font-semibold
         text-[19px] leading-[24px]
         tracking-normal
         bg-[linear-gradient(270deg,#17284D_0%,#5A72A7_100%)]
         bg-clip-text text-transparent mx-5"
            >
                Why Risk Management Is Your Superpower
            </h3>

            <div class="relative mt-6 overflow-hidden rounded-b-2xl bg-[#eef0f6]">
                <img
                    src="/img/blog_img_3.webp"
                    alt="Blog cover"
                    class="h-56 w-full object-cover"
                />
                <span
                    class="absolute left-4 top-4 rounded-full  bg-[linear-gradient(270deg,#17284D_0%,#5A72A7_100%)] px-4 py-1 text-[12px] font-semibold text-white"
                >
                    Business
                </span>
                <a
                    href="/blog/3"
                    class="absolute inset-x-0 bottom-0 translate-y-full bg-[#1d2d53] py-3 text-center text-[14px] font-semibold text-white transition-all duration-300 group-hover:translate-y-0"
                >
                    Read More &#8599;
                </a>
            </div>
        </article>
    </div>
</section>
