---
export interface ServiceCard {
    title: string;
    description: string;
}

export interface CalculatorCard {
    title: string;
    description: string;
}

export interface Props {
    breadcrumb?: string[];
    heroTitle: string;
    heroSubtitle: string;
    heroImage: string;
    heroCtaPrimaryText: string;
    heroCtaPrimaryHref?: string;
    heroCtaSecondaryText?: string;
    heroCtaSecondaryHref?: string;
    aboutTitle: string;
    aboutText: string[];
    aboutImage: string;
    benefits: string[];
    calculators: CalculatorCard[];
    servicesTitle: string;
    servicesSubtitle?: string;
    services: ServiceCard[];
    ctaTitle: string;
    ctaSubtitle?: string;
    ctaPrimaryText: string;
    ctaPrimaryHref?: string;
    ctaSecondaryText?: string;
    ctaSecondaryHref?: string;
}

const {
    breadcrumb = ["Home", "Services", "Home Loan"],
    heroTitle,
    heroSubtitle,
    heroImage,
    heroCtaPrimaryText,
    heroCtaPrimaryHref = "/contact",
    heroCtaSecondaryText,
    heroCtaSecondaryHref = "/contact",
    aboutTitle,
    aboutText,
    aboutImage,
    benefits,
    calculators,
    servicesTitle,
    servicesSubtitle,
    services,
    ctaTitle,
    ctaSubtitle,
    ctaPrimaryText,
    ctaPrimaryHref = "/contact",
    ctaSecondaryText,
    ctaSecondaryHref = "/contact",
} = Astro.props;
---

<!-- Hero -->
<section class="relative overflow-hidden bg-[#0f2147] text-white">
    <img
        src={heroImage}
        alt={heroTitle}
        class="absolute inset-0 h-full w-full object-cover"
    />
    <div
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(15,40,71,0.78)_0%,rgba(30,58,95,0.78)_50%,rgba(45,90,143,0.78)_100%)]"
    >
    </div>

    <div class="relative mx-auto max-w-6xl px-6 pt-8">
        <nav
            aria-label="Breadcrumb"
            class="flex items-center gap-3 font-Arial text-[14px] leading-[20px] text-white/80"
        >
            {
                breadcrumb.map((item, index) => (
                    <>
                        {index > 0 && <span class="text-white/50">&#62;</span>}
                        <span>{item}</span>
                    </>
                ))
            }
        </nav>
    </div>

    <div
        class="relative mx-auto flex max-w-6xl flex-col items-center px-6 pb-16 pt-10 text-center lg:pb-24 lg:pt-14"
    >
        <div
            class="mx-auto inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 font-Arial text-[12px] leading-[18px] tracking-[0px] text-center text-white sm:text-[14px] sm:leading-[20px]"
        >
            <span class="inline-block h-2 w-2 rounded-full bg-emerald-400"
            ></span>
            Trusted by 15,000+ customers
        </div>

        <h1
            class="mt-5 font-Arial font-bold text-[32px] leading-[40px] tracking-[0px] text-center sm:text-[42px] sm:leading-[52px] lg:text-[58px] lg:leading-[90px]"
        >
            {heroTitle}
        </h1>
        <p
            class="mx-auto max-w-2xl font-Arial text-[16px] leading-[26px] tracking-[0px] text-center text-[#E5E7EB] sm:text-[18px] sm:leading-[28px] lg:text-[20px] lg:leading-[32.5px]"
        >
            {heroSubtitle}
        </p>

        <div class="mt-7 flex flex-wrap items-center justify-center gap-4">
            <a
                href={heroCtaPrimaryHref}
                class="inline-flex items-center justify-center gap-2
  rounded-full bg-white pl-6 pr-3 py-2
  font-Poppins font-semibold
  text-[15px] leading-[100%] tracking-normal
  text-[#1E2E4A]"
            >
                {heroCtaPrimaryText}
                <span class="text-white bg-primary rounded-full p-2"
                    >&#8594;</span
                >
            </a>
        </div>
    </div>
</section>

<!-- About + Calculators -->
<section class="bg-white py-12 lg:py-20">
    <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-7 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
            <div>
                <h2
                    class="font-Arial font-bold
  lg:text-[40px] text-[30px] leading-[55.03px]
  tracking-normal
  text-[#1E3A5F]"
                >
                    {aboutTitle}
                </h2>
                <div
                    class="mt-6 space-y-6
  font-Arial font-normal
  text-[20px] leading-[33px]
  tracking-normal
  text-[#364153]"
                >
                    {aboutText.map((para) => <p>{para}</p>)}
                </div>
                <div class="mt-10">
                    <h3
                        class="font-['Arial'] font-bold
  text-[30px] leading-[44.03px]
  tracking-normal
  text-[#1E3A5F]"
                    >
                        Key Benefits
                    </h3>
                    <ul
                        class="mt-4 space-y-4 font-Arial text-[16px] leading-[24px] text-[#2F3B4F]"
                    >
                        {
                            benefits.map((item) => (
                                <li class="flex items-start gap-4">
                                    <span
                                        class="mt-0.5 flex h-8 w-8 items-center justify-center rounded-full bg-[#1E3A5F] text-white shadow-[0_6px_16px_-8px_rgba(30,58,95,0.8)]"
                                        aria-hidden="true"
                                    >
                                        <svg
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            class="h-4 w-4"
                                        >
                                            <path d="M20 6L9 17l-5-5" />
                                        </svg>
                                    </span>
                                    <span class=" font-Arial font-normal text-[16px] leading-[26px] lg:text-[20px] lg:leading-[35px] tracking-normal text-[#1E2939]">
                                        {item}
                                    </span>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>

            <div>
                <div
                    class="overflow-hidden rounded-[18px] shadow-[0_20px_40px_-25px_rgba(15,40,71,0.5)]"
                >
                    <div class="relative h-[490px] w-full">
                        <!-- Image -->
                        <img
                            src={aboutImage}
                            alt={aboutTitle}
                            class="absolute inset-0 h-full w-full object-cover"
                        />

                        <!-- Gradient Overlay -->
                        <div
                            class="absolute inset-0 z-10
      bg-[linear-gradient(223.9deg,rgba(23,40,77,0.98)_5.93%,rgba(90,114,167,0.22)_98.8%)]"
                        >
                        </div>
                    </div>
                </div>

                <div class="mt-14 rounded-[16px] bg-[#EEF2F7] p-5">
                    <h4
                        class="text-center font-Arial text-[28px] font-bold leading-[40px] text-[#1E3A5F]"
                    >
                        Calculators
                    </h4>
                    <p
                        class="mx-auto mt-2 max-w-[380px] text-center font-Arial text-[16px] leading-[22px] text-[#364153]"
                    >
                        Use our tools to plan your home loan journey and
                        understand your options.
                    </p>
                    <div class="mt-5 grid gap-4 sm:grid-cols-2">
                        {
                            calculators.map((item) => (
                                <div
                                    class="rounded-[14px] bg-white p-4 shadow-[0px_1.21px_2.42px_-1.21px_rgba(0,0,0,0.10),0px_2.42px_3.63px_-0.61px_rgba(0,0,0,0.10) ring-1 ring-black/5"
                                >
                                    <div class="flex items-start gap-3">
                                        <span
                                            class="mt-0.5 p-1 inline-flex h-6 w-8 items-center justify-center rounded-[5px] bg-[#1E3A5F] text-white shadow-[0_6px_16px_-8px_rgba(30,58,95,0.8)]"
                                            aria-hidden="true"
                                        >
                                            <svg
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="h-4 w-4"
                                            >
                                                <path d="M6 6h12" />
                                                <path d="M6 12h12" />
                                                <path d="M6 18h8" />
                                            </svg>
                                        </span>
                                        <div>
                                            <p class="font-Arial font-bold text-[16px] leading-[21px] tracking-normal text-[#1E3A5F]">
                                                {item.title}
                                            </p>
                                            <p class="mt-1 font-Arial font-normal text-[10px] leading-[16px] tracking-normal text-[#364153]">
                                                {item.description}
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services -->
<section class="bg-[#F6F8FC] py-12 lg:py-20">
    <div class="mx-auto max-w-6xl px-6">
        <div class="text-center">
            <h2
                class="font-Arial text-[22px] font-bold text-[#1E2E4A] lg:text-[28px]"
            >
                {servicesTitle}
            </h2>
            {
                servicesSubtitle ? (
                    <p class="mx-auto mt-2 max-w-2xl text-[14px] text-[#6B7A93]">
                        {servicesSubtitle}
                    </p>
                ) : null
            }
        </div>

        <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {
                services.map((item) => (
                    <div class="rounded-[14px] bg-white p-5 shadow-[0_14px_30px_-20px_rgba(15,40,71,0.45)]">
                        <h3 class="font-Arial text-[14px] font-bold text-[#1E2E4A]">
                            {item.title}
                        </h3>
                        <p class="mt-2 text-[12px] leading-[20px] text-[#6B7A93]">
                            {item.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section class="bg-white py-12 lg:py-20">
    <div class="mx-auto max-w-6xl px-6">
        <div
            class="rounded-[22px] bg-[#16264D] px-6 py-10 text-center text-white shadow-[0_24px_50px_-30px_rgba(15,40,71,0.6)]"
        >
            <h2 class="font-Arial text-[20px] font-bold lg:text-[26px]">
                {ctaTitle}
            </h2>
            {
                ctaSubtitle ? (
                    <p class="mx-auto mt-2 max-w-2xl text-[13px] text-white/80">
                        {ctaSubtitle}
                    </p>
                ) : null
            }
            <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
                <a
                    href={ctaPrimaryHref}
                    class="inline-flex items-center justify-center rounded-full bg-white px-6 py-2 font-Arial text-[13px] font-semibold text-[#1E2E4A]"
                >
                    {ctaPrimaryText}
                </a>
                {
                    ctaSecondaryText ? (
                        <a
                            href={ctaSecondaryHref}
                            class="inline-flex items-center justify-center rounded-full border border-white/70 px-6 py-2 font-Arial text-[13px] font-semibold text-white hover:bg-white/10"
                        >
                            {ctaSecondaryText}
                        </a>
                    ) : null
                }
            </div>
        </div>
    </div>
</section>
