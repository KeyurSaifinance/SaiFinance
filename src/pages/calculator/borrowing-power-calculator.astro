---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Loan Repayment Calculator | SAI Finance">
    <Fragment slot="header">
        <Header />
    </Fragment>

    <section class="mx-auto max-w-7xl px-6 py-10 font-dm-sans">
        <iframe
            class="VisiCalcClass"
            id="Borrowing_Power_Calculator"
            src="https://www.visionabacus.net/Tools/B3/SuiteA/A200/Borrowing_Power_Calculator/FBAA"
            frameborder="0"
            scrolling="no"></iframe>
        <!-- </div> -->
    </section>

    <Fragment slot="footer">
        <Footer />
    </Fragment>
</Layout>
