---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CtaButton from "../components/CtaButton.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Calculators | SAI Finance">
    <Fragment slot="header">
        <Header />
    </Fragment>
    <!-- services hero section 1 -->
    <section class="relative overflow-hidden bg-[#0f2147] text-white">
        <img
            src="/img/services_hero.webp"
            alt="Our Services"
            class="absolute inset-0 h-full w-full object-cover"
        />
        <div
            class="absolute inset-0 bg-[linear-gradient(180deg,rgba(15,40,71,0.82)_0%,rgba(30,58,95,0.82)_50%,rgba(45,90,143,0.82)_100%)]"
        >
        </div>

        <div
            class="relative mx-auto max-w-6xl px-6 py-12 sm:py-16 lg:py-24 text-center"
        >
            <div
                class="mx-auto inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 font-Arial text-[12px] leading-[18px] tracking-[0px] text-center text-white sm:text-[14px] sm:leading-[20px]"
            >
                <span class="inline-block h-2 w-2 rounded-full bg-emerald-400"
                ></span>
                Trusted by 700+ customers
            </div>

            <h1
                class="mt-5 font-Arial font-bold text-[32px] leading-[40px] tracking-[0px] text-center sm:text-[42px] sm:leading-[52px] lg:text-[58px] lg:leading-[90px]"
            >
                Mortgage & Finance Calculators
            </h1>

            <p
                class="mx-auto mt-4 max-w-2xl font-Arial text-[16px] leading-[26px] tracking-[0px] text-center text-[#E5E7EB] sm:text-[18px] sm:leading-[28px] lg:text-[20px] lg:leading-[32.5px]"
            >
                Use our simple calculators to estimate your repayments and
                understand your borrowing capacity before applying for a loan.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-4">
                <CtaButton />
            </div>
        </div>
    </section>


    <!-- section 2 -->
    <section class="bg-[#f2f4f7] py-14 md:py-16 lg:py-20">
        <div class="mx-auto max-w-6xl px-6 lg:px-6">
            <div class="text-center">
                <h2
                    class="font-Arial font-bold text-[34px] leading-[42px] text-primary sm:text-[42px] sm:leading-[52px]"
                >
                    Explore Our Calculators
                </h2>
                <p
                    class="mt-3 font-Arial text-[18px] leading-[30px] text-[#5c6f87]"
                >
                    Choose the calculator that best fits your financial planning
                    needs
                </p>
            </div>

            <div class="mt-12 grid gap-8 lg:grid-cols-2">
                <article
                    class="overflow-hidden rounded-2xl border border-[#d9e0ea] bg-white shadow-[0_10px_30px_-18px_rgba(15,33,71,0.35)]"
                >
                    <div class="relative h-[180px]">
                        <img
                            src="/img/home_loan_1.png"
                            alt="Loan Repayment Calculator"
                            class="h-full w-full object-cover"
                        />
                        <div class="absolute inset-0 bg-[#1f3e6f]/55"></div>
                        <div
                            class="absolute bottom-[-30px] left-1/2 inline-flex h-[78px] w-[78px] -translate-x-1/2 items-center justify-center rounded-2xl border border-[#dbe4ef] bg-white text-primary shadow-md"
                        >
                            <Icon name="ph:calculator" size="36" />
                        </div>
                    </div>

                    <div class="px-6 pb-6 pt-12">
                        <h3
                            class="font-Arial text-[32px] font-bold leading-[42px] text-primary sm:text-[37px] sm:leading-[48px]"
                        >
                            Loan Repayment Calculator
                        </h3>
                        <p
                            class="mt-2 font-Arial text-[17px] leading-[30px] text-[#4f6178]"
                        >
                            Estimate your monthly mortgage repayments based on
                            loan amount, interest rate, and loan term. This
                            calculator helps you understand your potential
                            repayments before applying for a loan.
                        </p>

                        <p
                            class="mt-5 font-Arial text-[14px] font-bold uppercase tracking-[0.06em] text-primary"
                        >
                            Features
                        </p>
                        <ul class="mt-3 space-y-2">
                            <li
                                class="flex items-center gap-2 font-Arial text-[17px] leading-[28px] text-[#4f6178]"
                            >
                                <Icon
                                    name="ph:check-circle"
                                    size="17"
                                    class="text-primary"
                                />
                                Calculate monthly repayments
                            </li>
                            <li
                                class="flex items-center gap-2 font-Arial text-[17px] leading-[28px] text-[#4f6178]"
                            >
                                <Icon
                                    name="ph:check-circle"
                                    size="17"
                                    class="text-primary"
                                />
                                View total interest payable
                            </li>
                            <li
                                class="flex items-center gap-2 font-Arial text-[17px] leading-[28px] text-[#4f6178]"
                            >
                                <Icon
                                    name="ph:check-circle"
                                    size="17"
                                    class="text-primary"
                                />
                                Compare loan scenarios
                            </li>
                        </ul>

                        <a
                            href="/calculator/loan-repayment-calculator"
                            class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-5 py-3.5 font-Arial text-[18px] font-bold text-white transition hover:opacity-90"
                        >
                            Use Calculator
                            <Icon name="ph:arrow-right" size="16" />
                        </a>
                    </div>
                </article>

                <article
                    class="overflow-hidden rounded-2xl border border-[#d9e0ea] bg-white shadow-[0_10px_30px_-18px_rgba(15,33,71,0.35)]"
                >
                    <div class="relative h-[180px]">
                        <img
                            src="/img/service_img_2.webp"
                            alt="Borrowing Power Calculator"
                            class="h-full w-full object-cover"
                        />
                        <div class="absolute inset-0 bg-[#1f3e6f]/55"></div>
                        <div
                            class="absolute bottom-[-30px] left-1/2 inline-flex h-[78px] w-[78px] -translate-x-1/2 items-center justify-center rounded-2xl border border-[#dbe4ef] bg-white text-primary shadow-md"
                        >
                            <Icon name="ph:house-line" size="36" />
                        </div>
                    </div>

                    <div class="px-6 pb-6 pt-12">
                        <h3
                            class="font-Arial text-[32px] font-bold leading-[42px] text-primary sm:text-[37px] sm:leading-[48px]"
                        >
                            Borrowing Power Calculator
                        </h3>
                        <p
                            class="mt-2 font-Arial text-[17px] leading-[30px] text-[#4f6178]"
                        >
                            Find out how much you may be able to borrow based on
                            your income, expenses, and financial commitments.
                        </p>

                        <p
                            class="mt-5 font-Arial text-[14px] font-bold uppercase tracking-[0.06em] text-primary"
                        >
                            Features
                        </p>
                        <ul class="mt-3 space-y-2">
                            <li
                                class="flex items-center gap-2 font-Arial text-[17px] leading-[28px] text-[#4f6178]"
                            >
                                <Icon
                                    name="ph:check-circle"
                                    size="17"
                                    class="text-primary"
                                />
                                Estimate borrowing capacity
                            </li>
                            <li
                                class="flex items-center gap-2 font-Arial text-[17px] leading-[28px] text-[#4f6178]"
                            >
                                <Icon
                                    name="ph:check-circle"
                                    size="17"
                                    class="text-primary"
                                />
                                Understand affordability
                            </li>
                            <li
                                class="flex items-center gap-2 font-Arial text-[17px] leading-[28px] text-[#4f6178]"
                            >
                                <Icon
                                    name="ph:check-circle"
                                    size="17"
                                    class="text-primary"
                                />
                                Plan your property purchase
                            </li>
                        </ul>

                        <a
                            href="/calculator/borrowing-power-calculator"
                            class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-primary px-5 py-3.5 font-Arial text-[18px] font-bold text-white transition hover:opacity-90"
                        >
                            Check Borrowing Power
                            <Icon name="ph:arrow-right" size="16" />
                        </a>
                    </div>
                </article>
            </div>
        </div>
    </section>



    <Fragment slot="footer">
        <Footer />
    </Fragment>
</Layout>
