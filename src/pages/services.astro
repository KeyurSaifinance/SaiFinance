---
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
import CtaButton from "../components/CtaButton.astro";
import Servicess from "../components/Services.astro";
---

<Layout>
    <Fragment slot="header">
        <Header />
    </Fragment>

    <!-- services hero section 1 -->
    <section class="relative overflow-hidden bg-[#0f2147] text-white">
        <img
            src="/img/services_hero.webp"
            alt="Our Services"
            class="absolute inset-0 h-full w-full object-cover"
        />
        <div
            class="absolute inset-0 bg-[linear-gradient(180deg,rgba(15,40,71,0.82)_0%,rgba(30,58,95,0.82)_50%,rgba(45,90,143,0.82)_100%)]"
        >
        </div>

        <div
            class="relative mx-auto max-w-6xl px-6 py-12 sm:py-16 lg:py-24 text-center"
        >
            <div
                class="mx-auto inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 font-Arial text-[12px] leading-[18px] tracking-[0px] text-center text-white sm:text-[14px] sm:leading-[20px]"
            >
                <span class="inline-block h-2 w-2 rounded-full bg-emerald-400"
                ></span>
                Trusted by 15,000+ customers
            </div>

            <h1
                class="mt-5 font-Arial font-bold text-[32px] leading-[40px] tracking-[0px] text-center sm:text-[42px] sm:leading-[52px] lg:text-[58px] lg:leading-[90px]"
            >
                Flexible Mortgage Solutions
                <span
                    class="block font-Arial font-bold text-[32px] leading-[40px] tracking-[0px] bg-gradient-to-r from-[#788FBF] to-[#5A72A7] bg-clip-text text-transparent sm:text-[42px] sm:leading-[50px] lg:text-[58px] lg:leading-[65px]"
                >
                    Tailored to You
                </span>
            </h1>

            <p
                class="mx-auto mt-4 max-w-2xl font-Arial text-[16px] leading-[26px] tracking-[0px] text-center text-[#E5E7EB] sm:text-[18px] sm:leading-[28px] lg:text-[20px] lg:leading-[32.5px]"
            >
                Whether you’re buying your first home, investing, refinancing or
                growing your business — we structure loans that work for your
                future.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-4">
                <CtaButton className="w-full justify-center sm:w-auto" />
                <a
                    href="/services"
                    class="inline-flex items-center justify-center gap-2
         rounded-full border border-white/30 bg-white/10
         px-6 py-2
         font-Arial font-normal
         text-[15px] leading-[28px] tracking-[0.5px]
         text-center text-white
         hover:bg-white/20"
                >
                    Learn More
                </a>
            </div>
        </div>
    </section>

    <!-- services section 2 -->
    <Servicess />

    <section class="bg-white py-0">
        <div class="mx-auto max-w-6xl px-6 flex justify-center">
            <a
                href="/contact"
                class="inline-flex items-center justify-center gap-2
         rounded-full bg-primary
         px-8 py-3
         font-Arial font-bold text-[10px]
         lg:text-[14px] leading-[24px] tracking-[0.5px]
         text-center text-white"
            >
                Get Started with a Free Consultation &#8594;
            </a>
        </div>
    </section>

    <!-- section 3 -->
    <section class="pt-5 lg:pt-18 pb-10">
        <div class="mx-auto max-w-6xl px-6 lg:px-0">
            <div class="mt-5">
                <h2
                    class="font-Arial font-bold
         lg:text-[40px] text-[30px] lg:leading-[48px] leading-[40px] tracking-[0px]
         text-center text-primary"
                >
                    Your Path to
                    <span
                        class="font-Arial font-bold
           lg:text-[40px] text-[30px] lg:leading-[48px] leading-[40px] tracking-[0px]
           text-center text-[#5A72A7]"
                    >
                        Approval
                    </span>
                    in 5 Simple Steps
                </h2>

                <p
                    class="mt-2
         font-Arial font-normal
         lg:text-[16px] text-[14px] leading-[28px] tracking-[0px]
         text-center
         text-[#4A5565]"
                >
                    Specialised mortgage solutions for every situation
                </p>
            </div>

            <div class="relative mt-5 lg:mt-12">
                <div class="absolute left-12 right-12 top-14 hidden lg:block">
                </div>

                <div class="grid gap-10 lg:grid-cols-5">
                    <div class="flex flex-col lg:items-start items-center">
                        <div class="relative">
                            <div
                                class="flex h-28 w-28 items-center justify-center rounded-2xl bg-white"
                            >
                                <img
                                    src="/img/icon_img_8.png"
                                    alt=""
                                    class="h-14 w-14"
                                />
                            </div>
                            <img
                                src="/img/icon_img_12.png"
                                alt="Process Flow"
                                class="pointer-events-none absolute left-[100%] top-[45%] hidden w-[340%] max-w-none -translate-y-1/2 lg:block"
                            />
                            <span
                                class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
                            >
                                01
                            </span>
                        </div>
                        <h3
                            class="mt-8 font-dm-sans font-semibold text-[20px] leading-[100%] tracking-normal text-[#1C1C1C]"
                        >
                            Initial consultation
                        </h3>
                    </div>

                    <div class="flex flex-col lg:items-start items-center">
                        <div class="relative">
                            <div
                                class="flex h-28 w-28 items-center justify-center rounded-3xl bg-primary text-white shadow-lg"
                            >
                                <img
                                    src="/img/icon_img_9.png"
                                    alt=""
                                    class="w-12 h-12"
                                />
                            </div>
                            <span
                                class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
                            >
                                02
                            </span>
                        </div>
                        <h3
                            class="mt-8 font-dm-sans font-semibold text-[20px] leading-[100%] tracking-normal text-[#1C1C1C]"
                        >
                            Present loan options
                        </h3>
                    </div>

                    <div class="flex flex-col lg:items-start items-center">
                        <div class="relative">
                            <div
                                class="flex h-28 w-28 items-center justify-center"
                            >
                                <img
                                    src="/img/icon_img_10.png"
                                    alt=""
                                    class=""
                                />
                            </div>
                            <img
                                src="/img/icon_img_12.png"
                                alt="Process Flow"
                                class="pointer-events-none absolute left-[100%] top-[45%] hidden w-[335%] max-w-none -translate-y-1/2 lg:block"
                            />
                            <span
                                class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
                            >
                                03
                            </span>
                        </div>
                        <h3
                            class="mt-8 font-dm-sans font-semibold text-[20px] leading-[100%] tracking-normal text-[#1C1C1C]"
                        >
                            Lodge application
                        </h3>
                    </div>

                    <div class="flex flex-col lg:items-start items-center">
                        <div class="relative">
                            <div
                                class="flex h-28 w-28 items-center justify-center rounded-3xl bg-primary text-white shadow-lg"
                            >
                                <img
                                    src="/img/icon_img_11.png"
                                    alt=""
                                    class="ml-3"
                                />
                            </div>
                            <span
                                class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
                            >
                                04
                            </span>
                        </div>
                        <h3
                            class="mt-8 font-dm-sans font-semibold text-[20px] leading-[100%] tracking-normal text-[#1C1C1C]"
                        >
                            Formal approval
                        </h3>
                    </div>

                    <div class="flex flex-col lg:items-start items-center">
                        <div class="relative">
                            <div
                                class="flex h-28 w-28 items-center justify-center"
                            >
                                <img
                                    src="/img/icon_img_10.png"
                                    alt=""
                                    class=""
                                />
                            </div>
                            <span
                                class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
                            >
                                05
                            </span>
                        </div>
                        <h3
                            class="mt-8 font-Poppins text-[18px] font-semibold text-[#0f2147]"
                        >
                            Settlement
                        </h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="mx-auto max-w-6xl px-6 flex justify-center mt-16">
            <a
                href="/contact"
                class="inline-flex items-center justify-center gap-2
               rounded-full
               bg-gradient-to-b from-[#17284D] to-[#5A72A7]
               px-8 py-3
               font-[Arial] font-bold
               text-[10px] lg:text-[14px]
               leading-[24px] tracking-[0.5px]
               text-center text-white
               "
            >
                Start Your Application Now &#8594;
            </a>
        </div>
    </section>
</Layout>
