---
import Header from "../../components/Header.astro";
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import ServiceLayout from "../../components/ServiceLayout.astro";

const data = {
    breadcrumb: ["Home", "Services", "Home Loan"],
    heroTitle: "Home Loans Made Simple",
    heroSubtitle:
        "Get competitive rates, flexible terms, and expert guidance from start to finish — tailored to your goals.",
    heroImage: "/img/services_hero.webp",
    heroCtaPrimaryText: "Apply for Home Loan",
    heroCtaSecondaryText: "Book a Free Call",
    aboutTitle: "About This Service",
    aboutText: [
        "Buying your first home is an exciting milestone, but navigating the mortgage process can feel overwhelming. Our First Time Home Buyer service simplifies every step, from understanding your borrowing capacity to securing the best loan terms.",
        "Our team specializes in helping first-time buyers understand their options, compare products, and make informed decisions. We handle the paperwork, negotiate on your behalf, and ensure you get the most favorable terms for your circumstances.",
        "We work with over 60 lenders to find competitive rates and flexible options tailored to your financial situation. Whether you need guidance on deposit size, eligibility, or government assistance schemes — we’re here to help.",
    ],
    aboutImage: "/img/service_img_2.png",
    benefits: [
        "Access to 40+ lenders and competitive rates",
        "Low deposit options for first home buyers",
        "First Home Owner Grant assistance",
        "Dedicated support throughout the process",
    ],
    calculators: [
        {
            title: "Mortgage Calculator",
            description: "Estimate repayments based on loan amount and term.",
        },
        {
            title: "Borrowing Power",
            description: "Find out how much you may be able to borrow.",
        },
    ],
    servicesTitle: "Our Loan Services",
    servicesSubtitle:
        "Comprehensive mortgage solutions designed to meet your unique financial needs and goals.",
    services: [
        {
            title: "First Home Buyers",
            description:
                "Guidance for eligible first-home buyers with tailored loan options.",
        },
        {
            title: "Refinancing",
            description:
                "Reduce your repayments or unlock equity with competitive rates.",
        },
        {
            title: "Investment Properties",
            description:
                "Smart lending strategies for growing your property portfolio.",
        },
        {
            title: "Construction Loans",
            description:
                "Flexible funding options for building or renovating your home.",
        },
    ],
    ctaTitle: "Ready to Apply for Your First Home Loan?",
    ctaSubtitle:
        "Take the first step toward homeownership today with expert guidance.",
    ctaPrimaryText: "Apply Now",
    ctaSecondaryText: "Book Free Call",
};
---

<Layout>
    <Fragment slot="header">
        <Header />
    </Fragment>

    <ServiceLayout {...data} />

    <Fragment slot="footer">
        <Footer />
    </Fragment>
</Layout>
