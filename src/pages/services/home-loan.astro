---
import Header from "../../components/Header.astro";
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import ServiceLayout from "../../components/ServiceLayout.astro";

const data = {
    breadcrumb: ["Home", "Services", "Home Loan"],
    heroTitle: "Home Buyers",
    heroSubtitle:
        "Your journey to owning a home starts with clarity, confidence, and the right lending partner.",
    heroImage: "/img/services_hero.webp",
    heroCtaPrimaryText: "Apply for Home Loan",
    heroCtaSecondaryText: "Book a Free Call",
    aboutTitle: "Home Buyers",
    aboutText: [
        "Buying a home is one of the biggest milestones in life. Whether you are stepping into the market for the first time or upgrading to a home that better suits your family, the process can feel overwhelming.",
        "At SAI Finance, we make it simpler, clearer, and far less stressful by guiding you through every step - from understanding your borrowing power to securing the right loan structure for your goals.",
        "Our approach is personal. We take the time to understand your situation, your plans, and what home means for you. Then we match you with lending options that support your long-term financial wellbeing.",
    ],
    aboutImage: "/img/service_home.png",
    benefits: [
        "How much deposit you actually need",
        "What you can safely borrow",
        "How to structure your loan for long-term comfort",
        "Which government grants or schemes you may be eligible for",
        "How to prepare for pre-approval",
        "Seamless coordination with your real estate agent, conveyancer/solicitor, and lender",
    ],
    calculators: [
        {
            title: "Calculate Your Borrowing Power",
            description:
                "Find out how much you can borrow based on your income, expenses, and financial situation.",
            href: "/calculator/borrowing-power-calculator",
        },
        {
            title: "Calculate Repayment Options",
            description:
                "Explore different repayment scenarios and find the loan structure that works best for your budget.",
            href: "/calculator/loan-repayment-calculator",
        },
    ],
    servicesTitle: "Understanding Your Home Loan Options",
    servicesSubtitle:
        "From deposits to guarantees and government grants - we guide you through every option available.",
    services: [
        {
            title: "First-Home Buyers",
            description:
                "Support that helps you take the first step with confidence.Many first‑home buyers wish they had started planning earlier — but the real question is: What do you need to get started today?We help you understand: How much deposit you actually needWhat you can safely borrow How to structure your loan for long‑term comfort Which government grants or schemes you may be eligible for How to prepare for pre‑approval We also coordinate with your real estate agent, conveyancer/solicitor, and lender so the process feels seamless from start to finish.",
            icon: "ph:house-line",
            iconAlt: "First Home Buyers",
        },
        {
            title: "How Much Deposit Do You Need?",
            description:
                "More options than you might think.Saving a 20% deposit is ideal, but not always necessary. Depending on your situation, you may be able to: Borrow up to 90–95% of the property value Use genuine savings or a combination of savings and other contributions Access low‑deposit loan options Use a Family Guarantee to reduce or eliminate Lenders Mortgage Insurance (LMI) We’ll walk you through the pros, cons, and long‑term impact of each option so you can make an informed decision.",
            icon: "ph:bank",
            iconAlt: "Deposit Options",
        },
        {
            title: "Family Guarantee",
            description:
                "A smart way to boost your borrowing power.A Family Guarantee allows a parent or close family member to use a portion of their property’s equity as security for your loan. This can: Reduce your Loan‑to‑Value Ratio (LVR) Help you avoid LMI Allow you to borrow up to the full purchase price Get you into the market sooner We’ll help you understand how the guarantee works, the responsibilities involved, and how to structure it safely for everyone.",
            icon: "ph:hand-heart",
            iconAlt: "Family Guarantee",
        },
        {
            title: "First Home Owner Grant (FHOG)",
            description:
                "What you can access depends on your state. Each state and territory has different eligibility rules and grant amounts. We’ll help you check what applies to you and ensure your application is completed correctly.",
            icon: "ph:certificate",
            iconAlt: "FHOG",
        },
        {
            title: "Upgrading, Building, or Renovating",
            description:
                "When your next home needs to match your next chapter.If you’re planning to upgrade your home, you may be considering: Renovating your current property Buying a larger or more suitable home Building a new home A knockdown and rebuild Each option has different lending requirements, timelines, and cash‑flow considerations. We’ll help you compare the scenarios and secure the right finance solution for your upgrade.",
            icon: "ph:hammer",
            iconAlt: "Upgrading or Building",
        },
        {
            title: "How SAI Finance Helps",
            description:
                "Personalised guidance. Smarter lending. A smoother experience. We find the right loan for you — We compare your goals with thousands of lending options across major banks and specialist lenders. We negotiate on your behalf — Our relationships with lenders help us secure sharper rates and tailored offers. We handle the paperwork — From application to settlement, we manage the details so you can focus on your home. Our service is free — You don’t pay us; the lender you choose pays our fee.",
            icon: "ph:files",
            iconAlt: "How SAI Finance Helps",
        },
    ],
    ctaTitle: "Ready to Apply for Your First Home Loan?",
    ctaSubtitle:
        "Take the first step towards homeownership today with expert guidance from SAI Finance.",
    ctaPrimaryText: "Apply Now",
    ctaSecondaryText: "Book Free Call",
};
---

<Layout>
    <Fragment slot="header">
        <Header />
    </Fragment>

    <ServiceLayout {...data} />

    <Fragment slot="footer">
        <Footer />
    </Fragment>
</Layout>
