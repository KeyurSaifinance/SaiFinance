---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Services from "../components/Services.astro";
import Layout from "../layouts/Layout.astro";
import Review from "../components/Review.astro";
import AboutUs from "../components/AboutUs.astro";
import Blog from "../components/Blog.astro";
import Faq from "../components/Faq.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<Fragment slot="header">
		<Header />
	</Fragment>

	<!-- Hero (section 1)-->
	<section class="relative overflow-hidden bg-[#0f2147] text-white">
		<div class="absolute inset-0">
			<img
				src="/img/hero.webp"
				alt="SAI Finance"
				class="h-full w-full object-cover"
			/>
			<div class="absolute"></div>
		</div>

		<div class="relative mx-auto max-w-6xl px-0 py-16 lg:py-24">
			<div class="max-w-2xl">
				<span
					class="inline-flex items-center gap-2
         rounded-full border border-white/30
         px-6 py-1
         font-Poppins font-medium
         text-[21.74px] leading-[32.61px] tracking-normal
         capitalize
         text-white/90"
				>
					+ Expert Financing +
				</span>

				<h1 class="mt-6 text-4xl font-bold leading-tight lg:text-5xl">
					Build Wealth <br /> Through Property <br />— with the right <br
					/> Finance Strategy.
				</h1>
			</div>

			<p
				class="mt-4 max-w-xl
         font-dm-sans font-normal
         text-[21.74px] leading-[29.13px] tracking-normal
         text-white/80"
			>
				Specialised mortgage solutions for Australian property investors
				and first home buyers, backed by expert guidance on every step
				of the way.
			</p>

			<div class="mt-8 flex flex-wrap items-center gap-4">
				<a
					href="/contact"
					class="inline-flex items-center gap-2
         rounded-full
         bg-white
         border border-[#9CABC3]
         pl-5 pr-2 py-2
         font-Poppins font-bold
         text-[15px] leading-[100%] tracking-normal
         text-[#9CABC3]"
				>
					Book a Free Strategy Call
					<span
						class="inline-flex h-8 w-8 items-center justify-center
           rounded-full bg-[#0f2147] text-white"
					>
						&#8599;
					</span>
				</a>

				<a
					href="tel:+61433967374"
					class="inline-flex items-center gap-2 text-sm font-semibold text-white/90"
				>
					<span
						class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/40"
					>
						&#9742;
					</span>
					<span
						class="font-Inter font-normal text-[15.22px] leading-[15.22px] tracking-normal text-white"
					>
						Explore your borrowing power
						<span
							class="block
         font-Poppins font-medium
         text-[17.39px] leading-[28.26px] tracking-normal
         text-white/70 mt-1"
						>
							+61 433 967 374
						</span>
					</span>
				</a>
			</div>
		</div>

		<div
			class="absolute bottom-0 right-0 hidden md:block bg-white rounded-tl-4xl shadow-lg"
		>
			<img
				src="/img/img_1.webp"
				alt="Chat with us"
				class="h-[70px] w-auto rounded-lg shadow-lg"
				loading="lazy"
			/>
		</div>
	</section>

	<!-- section 2 -->
	<Services />

	<!-- section 3 -->
	<section class="mt-8 mb-18">
		<div class="mx-auto max-w-7xl px-6">
			<div class="grid lg:grid-cols-2 lg:gap-12 gap-5">
				<!-- LEFT SIDE -->
				<div class="flex flex-col">
					<div class="flex lg:flex-row flex-col gap-10 lg:ml-20">
						<!-- Badge -->
						<div>
							<span
								class="inline-flex items-center justify-center
                 rounded-full bg-[#1d2d53]
                 w-34 px-3 py-1
                 text-[18px] leading-[28px]
                 font-normal text-white capitalize"
							>
								Our Value
							</span>
						</div>

						<div class="">
							<!-- Heading -->
							<h1
								class="font-dm-sans font-semibold
                 text-4xl text-5xl lg:text-[40px]
                 leading-tight lg:leading-[50px]
                 bg-gradient-to-b from-[#5A72A7] to-[#17284D]
                 bg-clip-text text-transparent"
							>
								Your success <br class="hidden sm:block" />
								is our priority.
							</h1>

							<!-- Paragraph -->
							<p
								class="mt-2 max-w-lg font-Inter
                 text-[16px] leading-[28px]
                 text-[#15274B]"
							>
								Our mission is to empower businesses of all
								sizes to thrive in an ever-changing marketplace.
							</p>
						</div>
					</div>
					<!-- Image -->
					<img
						src="/img/our_value.webp"
						alt="SAI Finance"
						class="w-full h-full lg:-mt-24 lg:-ml-16"
					/>
				</div>

				<!-- RIGHT SIDE VALUES -->
				<div class="grid gap-y-4 gap-x-8 lg:grid-cols-2 grid-cols-1">
					<!-- Item -->
					<div class="flex flex-col items-start gap-4">
						<div>
							<img src="/img/icon_1.png" class="w-12 h-12" />
						</div>
						<div>
							<h3
								class="font-Poppins font-semibold
         text-[20px] leading-[26.8px] tracking-normal
         bg-gradient-to-l from-[#17284D] to-[#5A72A7]
         bg-clip-text text-transparent"
							>
								40+ lenders
							</h3>

							<p
								class="mt-2 font-Inter font-normal text-[15px] leading-[26px] tracking-normal text-primary"
							>
								Our lending portfolio includes all major banks,
								cooperatives, and non-banking financial
								institutions.
							</p>
						</div>
					</div>

					<div class="flex flex-col items-start gap-4">
						<div>
							<img src="/img/icon_2.png" class="w-12 h-12" />
						</div>
						<div>
							<h3
								class="font-Poppins font-semibold
         text-[20px] leading-[26.8px] tracking-normal
         bg-gradient-to-l from-[#17284D] to-[#5A72A7]
         bg-clip-text text-transparent"
							>
								Personalised Loan Guidance
							</h3>
							<p
								class="mt-2 font-Inter font-normal text-[15px] leading-[26px] tracking-normal text-primary"
							>
								We tailor our services to each client’s unique
								needs, aligning our approach with their
								financial goals and current circumstances.
							</p>
						</div>
					</div>

					<div class="flex flex-col items-start gap-4">
						<div>
							<img src="/img/icon_3.png" class="w-12 h-12" />
						</div>
						<div>
							<h3
								class="font-Poppins font-semibold
         text-[20px] leading-[26.8px] tracking-normal
         bg-gradient-to-l from-[#17284D] to-[#5A72A7]
         bg-clip-text text-transparent"
							>
								Excellent Customer Service
							</h3>
							<p
								class="mt-2 font-Inter font-normal text-[15px] leading-[26px] tracking-normal text-primary"
							>
								We provide clear guidance and timely updates
								throughout the process to ensure a smooth and
								informed loan experience.
							</p>
						</div>
					</div>

					<div class="flex flex-col items-start gap-4">
						<div>
							<img src="/img/icon_5.png" class="w-12 h-12" />
						</div>
						<div>
							<h3
								class="font-Poppins font-semibold
         text-[20px] leading-[26.8px] tracking-normal
         bg-gradient-to-l from-[#17284D] to-[#5A72A7]
         bg-clip-text text-transparent"
							>
								Fast Approval Process
							</h3>
							<p
								class="mt-2 font-Inter font-normal text-[15px] leading-[26px] tracking-normal text-primary"
							>
								Experience fast, hassle-free loan approvals
								through our digitally managed process, supported
								by clear upfront document requirements.
							</p>
						</div>
					</div>

					<div class="flex flex-col items-start gap-4">
						<div>
							<img src="/img/icon_5.png" class="w-12 h-12" />
						</div>
						<div>
							<h3
								class="font-Poppins font-semibold
         text-[20px] leading-[26.8px] tracking-normal
         bg-gradient-to-l from-[#17284D] to-[#5A72A7]
         bg-clip-text text-transparent"
							>
								ACL, CRN Licensee & FBAA Member
							</h3>
							<p
								class="mt-2 font-Inter font-normal text-[15px] leading-[26px] tracking-normal text-primary"
							>
								In addition to our extensive experience and
								refined processes, we hold all required industry
								licenses and memberships, further strengthening
								our credibility.
							</p>
						</div>
					</div>

					<div
						class="flex flex-col items-center justify-center text-center"
					>
						<a
							href="/contact"
							class="inline-flex items-center gap-2
         rounded-full
         bg-primary
         border border-[#9CABC3]
         pl-5 pr-2 py-2
         font-Poppins font-bold
         text-[15px] leading-[100%] tracking-normal
         text-white"
						>
							More About Us
							<span
								class="inline-flex h-8 w-8 items-center justify-center
           rounded-full bg-white text-primary"
							>
								&#8599;
							</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- section 4 -->
	<section class="bg-[#f6f7fb] pt-18 pb-10">
		<div class="mx-auto max-w-6xl">
			<div
				class="flex items-center gap-2 text-sm font-semibold text-[#0f2147]"
			>
				<img src="/img/icon_img_6.png" class="" />
				<span class="font-dm-sans font-semibold text-[16px]">
					How it works
				</span>
				<img src="/img/icon_img_7.png" class="" />
			</div>

			<div class="mt-5">
				<h2
					class="font-dm-sans font-semibold text-[40px] leading-[50px] text-primary"
				>
					Our engagement <br /> process:
				</h2>

				<p
					class="font-Arial mt-2 font-normal text-[16px] leading-[28px] tracking-normal text-[#4A5565]"
				>
					From initial consultation to settlement,<br /> we guide you through
					every step.
				</p>
			</div>

			<div class="relative mt-12">
				<div
					class="pointer-events-none absolute left-12 right-12 top-14 hidden border-t border-dashed border-[#c8d0df] lg:block"
				>
				</div>

				<div class="grid gap-10 lg:grid-cols-5">
					<div class="flex flex-col items-start">
						<div class="relative">
							<div
								class="flex h-28 w-28 items-center justify-center rounded-2xl bg-white"
							>
								<img
									src="/img/icon_img_8.png"
									alt=""
									class="h-14 w-14"
								/>
							</div>
							<!-- <img
								src="/img/icon_img_12.png"
								alt="Process Flow"
								class="pointer-events-none absolute left-[120%] top-1/2 hidden w-44 -translate-y-1/2 lg:block"
							/> -->
							<span
								class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
							>
								01
							</span>
						</div>
						<h3
							class="mt-8 font-dm-sans font-semibold text-[20px] leading-[100%] tracking-normal text-[#1C1C1C]"
						>
							Initial consultation
						</h3>

						<p
							class="mt-2 font-dm-sans font-normal text-[15px] leading-[24px] tracking-normal text-[#636363]"
						>
							We take into account your financial position,
							including your income, existing liabilities, and
							overall requirements.
						</p>
					</div>

					<div class="flex flex-col items-start">
						<div class="relative">
							<div
								class="flex h-28 w-28 items-center justify-center rounded-3xl bg-[linear-gradient(270deg,_#17284D_0%,_#5A72A7_100%)] text-white shadow-lg"
							>
								<img
									src="/img/icon_img_9.png"
									alt=""
									class="w-12 h-12"
								/>
							</div>
							<span
								class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
							>
								02
							</span>
						</div>
						<h3
							class="mt-8 font-dm-sans font-semibold text-[20px] leading-[100%] tracking-normal text-[#1C1C1C]"
						>
							Present loan options
						</h3>
						<p
							class="mt-2 font-dm-sans font-normal text-[15px] leading-[24px] tracking-normal text-[#636363]"
						>
							We present a range of loan options from various
							lenders that best align with your requirements and
							guide you in selecting the most suitable one.
						</p>
					</div>

					<div class="flex flex-col items-start">
						<div class="relative">
							<div
								class="flex h-28 w-28 items-center justify-center rounded-3xl bg-white shadow-sm"
							>
								<img
									src="/img/icon_img_10.png"
									alt=""
									class=""
								/>
							</div>
							<span
								class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
							>
								03
							</span>
						</div>
						<h3
							class="mt-8 font-dm-sans font-semibold text-[20px] leading-[100%] tracking-normal text-[#1C1C1C]"
						>
							Lodge application
						</h3>
						<p
							class="mt-2 font-dm-sans font-normal text-[15px] leading-[24px] tracking-normal text-[#636363]"
						>
							We securely collect the required documentation
							through our digital process and assist you in
							lodging your loan application as quickly as
							possible.
						</p>
					</div>

					<div class="flex flex-col items-start">
						<div class="relative">
							<div
								class="flex h-28 w-28 items-center justify-center rounded-3xl bg-[linear-gradient(270deg,_#17284D_0%,_#5A72A7_100%)] text-white shadow-lg"
							>
								<img
									src="/img/icon_img_11.png"
									alt=""
									class="ml-3"
								/>
							</div>
							<span
								class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
							>
								04
							</span>
						</div>
						<h3
							class="mt-8 font-dm-sans font-semibold text-[20px] leading-[100%] tracking-normal text-[#1C1C1C]"
						>
							Formal approval
						</h3>
						<p
							class="mt-2 font-dm-sans font-normal text-[15px] leading-[24px] tracking-normal text-[#636363]"
						>
							As one of the top-rated mortgage brokers, we can
							help you get pre-qualified, obtain lender
							pre-approval, or secure a commitment letter from our
							network of 40+ lenders—often within just one day.
						</p>
					</div>

					<div class="flex flex-col items-start">
						<div class="relative">
							<div
								class="flex h-28 w-28 items-center justify-center rounded-3xl bg-white shadow-sm"
							>
								<img
									src="/img/icon_img_10.png"
									alt=""
									class=""
								/>
							</div>
							<span
								class="absolute -bottom-3 left-1/2 -translate-x-1/2 flex items-center justify-center w-[30px] h-[23px] rounded-[5px] border border-[#16161626] bg-[linear-gradient(93.79deg,_rgba(72,86,117,0.2)_2.94%,_rgba(255,255,255,0.2)_95.79%)] p-[9px] font-dm-sans font-medium text-[12px] leading-[24.8px] tracking-normal text-black"
							>
								05
							</span>
						</div>
						<h3
							class="mt-8 font-Poppins text-[18px] font-semibold text-[#0f2147]"
						>
							Settlement
						</h3>
						<p
							class="mt-2 font-dm-sans font-normal text-[15px] leading-[24px] tracking-normal text-[#636363]"
						>
							We support you through every stage of the loan
							process—from approval to disbursement—ensuring a
							smooth path to settlement for your property or
							investment.
						</p>
					</div>
				</div>
			</div>

			<h1
				class="font-dm-sans font-normal text-[17px] leading-[28px] tracking-normal text-center mt-10"
			>
				We’ll contact you within one business day.
				<span
					class="font-dm-sans font-medium text-[17px] leading-[26.05px] text-center"
					>Get Free Quote</span
				>
			</h1>
		</div>
	</section>

	<!-- section 5 -->
	<section class="bg-[#F0F1F3] py-18">
		<div class="mx-auto max-w-6xl px-6">
			<div class="grid gap-14 lg:grid-cols-2 lg:items-center">
				<div>
					<span
						class="inline-flex items-center justify-center gap-2 rounded-full bg-[#1d2d53] px-5 py-2 text-center font-dm-sans text-[16px] font-medium leading-[26px] text-white"
					>
						<img src="/img/Text.png" alt="" />
						Trusted Company
						<img src="/img/Text.png" alt="" />
					</span>

					<h2
						class="mt-5 font-Poppins font-semibold
         text-[40px] leading-[50px]
         tracking-normal
         bg-gradient-to-l from-[#17284D] to-[#5A72A7]
         bg-clip-text text-transparent"
					>
						Digital Application <br />
						Enables Fast and <br />
						Reliable Service to Client
					</h2>

					<p
						class="mt-2 font-Poppins font-medium
         text-[16px] leading-[30px]
         tracking-normal
         capitalize
         text-[#636363]"
					>
						SAI Finance shops for your dream home or already have a
						purchase contract? As one of Perth top-rated mortgage
						brokers, we can help get you pre-qualified, pre-approved
						by a lender, or help you obtain a commitment letter from
						our range of 40+ lenders in as little as one day.
					</p>
				</div>

				<div>
					<img
						src="/img/image.webp"
						alt="SAI Finance"
						class="h-full w-full rounded-xl object-cover"
					/>
				</div>
			</div>

			<div
				class="mt-12 grid lg:gap-0 gap-6 lg:grid-cols-[1fr_1fr_auto] lg:items-start"
			>
				<div class="grid gap-6 lg:w-[430px]">
					<div
						class="flex items-center gap-4 rounded-lg bg-[#DFE2E7] p-5"
					>
						<div
							class="flex h-12 w-18 items-center justify-center rounded-lg bg-primary text-white"
						>
							<span class="font-dm-sans text-[26px] font-semibold"
								>1</span
							>
						</div>
						<p
							class="font-Poppins font-semibold
         text-[16px] leading-[25.22px]
         tracking-normal
         text-primary"
						>
							We have digitized the entire loan application
							process
						</p>
					</div>

					<div
						class="flex items-center gap-4 rounded-2xl bg-[#DFE2E7] p-5"
					>
						<div
							class="flex h-12 w-13 items-center justify-center rounded-lg bg-primary text-white"
						>
							<span class="font-dm-sans text-[26px] font-semibold"
								>2</span
							>
						</div>
						<p
							class="font-Poppins font-semibold
         text-[16px] leading-[25.22px]
         tracking-normal
         text-primary"
						>
							Secured digital forms
						</p>
					</div>

					<div
						class="flex items-center gap-4 rounded-2xl bg-[#DFE2E7] p-5"
					>
						<div
							class="flex h-12 w-24 items-center justify-center rounded-lg bg-primary text-white"
						>
							<span class="font-dm-sans text-[26px] font-semibold"
								>3</span
							>
						</div>
						<p
							class="font-Poppins font-semibold
         text-[16px] leading-[25.22px]
         tracking-normal
         text-primary"
						>
							Secured and encrypted data to ensure a secure
							end-to-end loan process
						</p>
					</div>
				</div>

				<div class="grid gap-6 lg:w-[400px]">
					<div
						class="flex items-center gap-4 rounded-2xl bg-[#DFE2E7] p-5"
					>
						<div
							class="flex h-12 w-14 items-center justify-center rounded-lg bg-primary text-white"
						>
							<span class="font-dm-sans text-[26px] font-semibold"
								>4</span
							>
						</div>
						<p
							class="font-Poppins font-semibold
         text-[16px] leading-[25.22px]
         tracking-normal
         text-primary"
						>
							Save loan application time
						</p>
					</div>

					<div
						class="flex items-center gap-4 rounded-2xl bg-[#DFE2E7] p-5"
					>
						<div
							class="flex h-12 w-14 items-center justify-center rounded-lg bg-primary text-white"
						>
							<span class="font-dm-sans text-[26px] font-semibold"
								>5</span
							>
						</div>
